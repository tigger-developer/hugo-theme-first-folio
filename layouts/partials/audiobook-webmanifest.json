{{- $book := partial "audiobook-data.html" . -}}
{{- $icon := or $book.image .Params.image.src -}}
{{- $iconURL := "" -}}
{{- if $icon -}}
  {{- if (urls.Parse $icon).Scheme -}}
    {{- $iconURL = $icon -}}
  {{- else if hasPrefix $icon "/" -}}
    {{- $iconURL = $icon | absURL -}}
  {{- else -}}
    {{- $iconURL = printf "%s%s" .Permalink $icon -}}
  {{- end -}}
{{- end -}}
{{- $manifest := dict
  "name" $book.title
  "short_name" (.LinkTitle | default .Title)
  "start_url" .RelPermalink
  "scope" .RelPermalink
  "display" "standalone"
  "description" $book.description
-}}
{{- if $iconURL -}}
  {{- $manifest = merge $manifest (dict "icons" (slice (dict "src" $iconURL "sizes" "512x512" "type" "image/jpeg" "purpose" "any"))) -}}
{{- end -}}
{{- $manifest | jsonify -}}
